OPENAI_API_KEY=sk-your-openai-api-key-here

# RouterAI (OpenAI-совместимый прокси): https://routerai.ru
OPENAI_BASE_URL=https://routerai.ru/api/v1
LLM_MODEL_FAST=qwen/qwen3.7-plus
LLM_MODEL_SMART=qwen/qwen3.7-plus

# Режим рынка: moex (портфель РФ, реальные данные) | synthetic (один актив)
MARKET_MODE=moex
PORTFOLIO_CONFIG=config/portfolio_ru.yaml
STRATEGIES_CONFIG=config/strategies_ru.yaml

# MOEX: true = только data/local/ (без сети). Сначала: python scripts/download_moex.py
MOEX_OFFLINE=true

# Шоки: shachi (3 регулятора) | legacy
SHOCK_BACKEND=shachi
SHOCK_INTERVAL=30
SIM_N_TICKS=120

# Live-дашборд: шоки и equity агентов в реальном времени
LIVE_VIZ=true
VIZ_PORT=8765
