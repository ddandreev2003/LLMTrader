OPENAI_API_KEY=sk-your-openai-api-key-here

# RouterAI (OpenAI-совместимый прокси): https://routerai.ru
OPENAI_BASE_URL=https://routerai.ru/api/v1
LLM_MODEL_FAST=qwen/qwen3.7-plus
LLM_MODEL_SMART=qwen/qwen3.7-plus
# QuantAgent: pattern/trend/indicator/decision = классический ТА (~5ms), без LLM.
# QUANT_USE_LLM=true — вернуть LLM для индикаторов и решения (медленно).
QUANT_ANALYSIS_MODE=text

# QuantAgent + OrderLog stream (T / GAZP / SBER)
# MARKET_MODE=orderlog_stream
# PORTFOLIO_CONFIG=config/portfolio_orderlog_tgs.yaml
# STRATEGIES_CONFIG=config/strategies_quantagent_tgs.yaml
# QUANT_CACHE_DECISIONS=true

# Режим рынка: moex | orderlog_intraday | orderlog_stream | synthetic
MARKET_MODE=orderlog_stream
PORTFOLIO_CONFIG=config/portfolio_orderlog_tgs.yaml
STRATEGIES_CONFIG=config/strategies_quantagent_tgs.yaml

# Intraday OrderLog (T / SBER):
# MARKET_MODE=orderlog_intraday
# PORTFOLIO_CONFIG=config/portfolio_intraday_tls.yaml
# STRATEGIES_CONFIG=config/strategies_intraday_tls.yaml
# SHOCK_INTERVAL=36
# ORDERLOG_DIR=datasets/moex/orderlog

# MOEX: true = только data/local/ (без сети). Сначала: python scripts/download_moex.py
MOEX_OFFLINE=true

# Шоки: shachi (3 регулятора) | legacy
SHOCK_BACKEND=shachi
SHOCK_INTERVAL=30
SIM_N_TICKS=500

# Live-дашборд: шоки и equity агентов в реальном времени
LIVE_VIZ=true
VIZ_PORT=8765
